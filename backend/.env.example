# Copy to .env and set real values for local development.
# On Render, set these in the service Environment dashboard (no .env file needed).

MONGODB_URL=mongodb+srv://<username>:<password>@<cluster-host>/?appName=Cluster0
SECRET_KEY=change-me-to-a-long-random-string

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
